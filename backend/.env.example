# Copy this file to .env and fill in your local values.

# MySQL connection
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=interview_prep_chatbot

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-string

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# CORS - comma-separated list of allowed frontend origins.
# Only needed when the frontend is on a different origin than the backend
# (e.g. local dev). Not needed for the Vercel "services" deployment, since
# same-domain rewrites make /api/* calls same-origin.
ALLOWED_ORIGINS=http://localhost:5173
